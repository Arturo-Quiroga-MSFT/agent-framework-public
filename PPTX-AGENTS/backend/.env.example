# PPTX Agents — Backend Environment
# Copy this to .env and fill in your values.

# ── Azure AI Foundry Project ──────────────────────────────────────────────
# Get from: https://ai.azure.com → Your Project → Overview
AZURE_AI_PROJECT_ENDPOINT=https://r2d2-foundry-001.services.ai.azure.com/api/projects/Main-Project

# ── Model deployment names ────────────────────────────────────────────────
# Analyst: multimodal, large context, visual reasoning
ANALYST_MODEL=gpt-5.3-codex

# Builder Step 1: slide content generation
CONTENT_MODEL=gpt-5.4

# Builder Step 2: python-pptx code generation
CODE_MODEL=gpt-5.3-codex

# ── Server ────────────────────────────────────────────────────────────────
API_PORT=8000
